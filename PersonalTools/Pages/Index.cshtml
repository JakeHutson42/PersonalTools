@page
@model PersonalTools.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container px-3 px-lg-4">
    <div class="row align-items-start gy-3 section-spacing">
        <div class="col-12 col-lg">
            <h1 class="page-title">Dashboard</h1>
            <p class="page-subtitle">
                A small personal tools app for Steam inventory lookups, CS2 skin tracking and notes.
            </p>
        </div>
    </div>

    <div class="row g-3 g-lg-4">
        @foreach (var tool in Model.Tools)
        {
            <div class="col-12 col-md-6 col-xl-4">
                <div class="card tool-card h-100 shadow-sm">
                    <div class="card-body p-4 d-flex flex-column">
                        <div class="tool-card-icon mb-3">
                            <i class="@tool.IconClass"></i>
                        </div>

                        <h2 class="h5 fw-semibold mb-2">@tool.Title</h2>

                        <p class="small-muted flex-grow-1">
                            @tool.Description
                        </p>

                        <a href="@tool.PageUrl" class="btn btn-primary mt-3">
                            @tool.ButtonText
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>